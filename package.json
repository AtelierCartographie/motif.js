{
  "name": "motif.js",
  "version": "0.1.0",
  "type": "module",
  "description": "A pattern generator that can be used in SVG environment or Canvas context",
  "main": "./dist/motif.js",
  "module": "./dist/motif.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/motif.mjs",
      "require": "./dist/motif.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite --config demo/vite.config.ts demo",
    "build": "tsc && vite build",
    "build:demo": "vite build --config demo/vite.config.ts demo",
    "preview": "npm run build"
  },
  "devDependencies": {
    "@fontsource-variable/atkinson-hyperlegible-mono": "^5.2.5",
    "@fontsource-variable/atkinson-hyperlegible-next": "^5.2.6",
    "@observablehq/plot": "^0.6.17",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@types/d3": "^7.4.3",
    "@types/node": "^20.10.0",
    "bertin": "^1.8.5",
    "d3": "^7.9.0",
    "d3-geo-projection": "^4.0.0",
    "shiki": "^3.22.0",
    "svelte": "^5.51.2",
    "typescript": "^5.3.3",
    "vite": "^6.4.1",
    "vite-plugin-dts": "^4.5.4"
  },
  "peerDependencies": {
    "@observablehq/plot": "^0.6.0"
  },
  "peerDependenciesMeta": {
    "@observablehq/plot": {
      "optional": true
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/AtelierCartographie/motif.js"
  },
  "keywords": [
    "pattern",
    "motif",
    "svg",
    "canvas",
    "generator"
  ],
  "author": "Thomas Ansart",
  "license": "ISC"
}
